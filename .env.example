# Sky Sentinel Environment Configuration
# Copy this to .env and fill in your values

# ── LLM Provider ─────────────────────────────────────────────
# "anthropic", "openai", "local", or "mock"
# Default is "mock" — the app runs fully without any API keys.
LLM_PROVIDER=mock

# Anthropic API Key (optional — required only when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI API Key (optional — required only when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Two-tier model routing (optional — faster seed, premium interactive)
LLM_MODEL_BATCH=claude-3-5-haiku-20241022
LLM_MODEL_INTERACTIVE=claude-sonnet-4-20250514

# ── Database ─────────────────────────────────────────────────
# Local development (default — stored next to backend code):
#   DATABASE_URL=sqlite:///./backend/db/sky_sentinel.db
#
# Docker / Coolify (recommended — mount persistent storage at /data):
DATABASE_URL=sqlite:////data/sky_sentinel.db

# ── CMS API ──────────────────────────────────────────────────
CMS_API_BASE_URL=https://data.cms.gov/data-api/v1/dataset

# ── Server ───────────────────────────────────────────────────
# Keep this aligned with the internal service port in Docker / Coolify.
BACKEND_PORT=8000
