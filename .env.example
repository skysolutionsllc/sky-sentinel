# Sky Sentinel Environment Configuration
# Copy this to .env and fill in your values

# ── LLM Provider ─────────────────────────────────────────────
# "openai", "anthropic", "local", or "mock"
# Default is "openai" — set to "mock" to run without API keys.
LLM_PROVIDER=openai

# OpenAI API Key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic API Key (optional — only if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=

# Three-tier model routing (batch = fast/cheap, interactive = premium reasoning)
LLM_MODEL_BATCH=gpt-4.1-mini
LLM_MODEL_INTERACTIVE=gpt-4.1

# ── Database ─────────────────────────────────────────────────
# Local development (default — stored next to backend code):
#   DATABASE_URL=sqlite:///./backend/db/sky_sentinel.db
#
# Docker / Coolify (recommended — mount persistent storage at /data):
DATABASE_URL=sqlite:////data/sky_sentinel.db

# ── CMS API ──────────────────────────────────────────────────
CMS_API_BASE_URL=https://data.cms.gov/data-api/v1/dataset

# ── Server ───────────────────────────────────────────────────
# Keep this aligned with the internal service port in Docker / Coolify.
BACKEND_PORT=8000
