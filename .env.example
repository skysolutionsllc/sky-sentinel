# Sky Sentinel Environment Configuration
# Copy this to .env and fill in your values

# Anthropic API Key (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# LLM Provider: "anthropic", "openai", or "mock"
LLM_PROVIDER=anthropic

# Two-tier model routing (optional — faster seed, premium interactive)
LLM_MODEL_BATCH=claude-3-5-haiku-20241022
LLM_MODEL_INTERACTIVE=claude-sonnet-4-20250514

# OpenAI API Key (optional fallback)
OPENAI_API_KEY=sk-your-key-here

# Database
DATABASE_URL=sqlite:///./backend/db/sky_sentinel.db

# CMS API
CMS_API_BASE_URL=https://data.cms.gov/data-api/v1/dataset

# Server
BACKEND_PORT=8000
FRONTEND_PORT=5173
